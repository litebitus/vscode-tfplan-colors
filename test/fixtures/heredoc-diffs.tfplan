  # mock_data.replaced will be updated in-place
  ~ resource "mock_data" "replaced" {
      ~ input = <<-EOT
          - old-mock-line-1
          + new-mock-line-1
          - old-mock-line-2
          + new-mock-line-2
        EOT
    }

  # mock_secret.gone will be destroyed
  - resource "mock_secret" "gone" {
      - payload = <<-EOT
            - destroyed-list-item
