{
  "name": "tfplan-colors",
  "displayName": "Terraform Plan Colors",
  "description": "Colorize saved terraform plan output, text or binary (rendered via terraform show): actions, gutter bars, and outline navigation",
  "version": "1.0.0",
  "publisher": "lite2073",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litebitus/vscode-tfplan-colors.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./extension.js",
  "scripts": {
    "version": "sh ./changelog.sh && git add CHANGELOG.md"
  },
  "activationEvents": [
    "onLanguage:plaintext"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tfplanColors.saveRenderedPlan",
        "title": "Save Rendered Plan As…",
        "category": "Terraform Plan",
        "icon": "$(save-as)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tfplanColors.saveRenderedPlan",
          "when": "resourceScheme == tfplan-show",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "tfplanColors.saveRenderedPlan",
          "when": "resourceScheme == tfplan-show"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "tfplanColors.binaryPlan",
        "displayName": "Terraform Plan",
        "selector": [
          {
            "filenamePattern": "*tfplan*"
          }
        ],
        "priority": "default"
      }
    ],
    "languages": [
      {
        "id": "terraform-plan",
        "aliases": [
          "Terraform Plan"
        ],
        "extensions": [
          ".tfplan"
        ],
        "filenamePatterns": [
          "*plan*.txt",
          "*.tfplan.txt",
          "*tfplan*"
        ],
        "firstLine": "^Terraform (used the selected providers|will perform)",
        "icon": {
          "light": "./fileicon.svg",
          "dark": "./fileicon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ]
  }
}
