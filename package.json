{
  "name": "tfplan-colors",
  "displayName": "Terraform Plan Colors",
  "description": "Colorize saved terraform plan output (.txt): actions, gutter bars, and outline navigation",
  "version": "0.1.2",
  "publisher": "lite2073",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litebitus/vscode-tfplan-colors.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:plaintext"
  ],
  "contributes": {
    "languages": [
      {
        "id": "terraform-plan",
        "aliases": [
          "Terraform Plan"
        ],
        "filenamePatterns": [
          "*plan*.txt",
          "*.tfplan.txt"
        ],
        "firstLine": "^Terraform (used the selected providers|will perform)",
        "icon": {
          "light": "./fileicon.svg",
          "dark": "./fileicon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ]
  }
}
