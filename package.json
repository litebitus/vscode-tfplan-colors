{
  "name": "tfplan-colors",
  "displayName": "Terraform Plan Colors",
  "description": "Colorize saved terraform plan output, text or binary: actions, gutter bars, plan summary by severity, and outline navigation",
  "version": "1.5.1",
  "publisher": "lite2073",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litebitus/vscode-tfplan-colors.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./extension.js",
  "devDependencies": {
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  },
  "scripts": {
    "version": "sh ./changelog.sh && git add CHANGELOG.md"
  },
  "activationEvents": [
    "onLanguage:terraform-plan",
    "onLanguage:plaintext"
  ],
  "contributes": {
    "configurationDefaults": {
      "[terraform-plan]": {
        "editor.wordWrap": "on",
        "editor.stickyScroll.defaultModel": "foldingProviderModel",
        "editor.renderLineHighlight": "all",
        "breadcrumbs.filePath": "last"
      }
    },
    "commands": [
      {
        "command": "tfplanColors.saveRenderedPlan",
        "title": "Save Rendered Plan As…",
        "category": "Terraform Plan",
        "icon": "$(save-as)"
      },
      {
        "command": "tfplanColors.copyResourceAddress",
        "title": "Copy Resource Address at Cursor",
        "category": "Terraform Plan"
      },
      {
        "command": "tfplanColors.showSummary",
        "title": "Summarize Plan",
        "category": "Terraform Plan",
        "icon": "$(list-tree)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "tfplanSummary",
          "name": "Plan Summary",
          "when": "tfplanColors.planActive"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "tfplanColors.showSummary",
          "when": "editorLangId == terraform-plan",
          "group": "navigation@1"
        },
        {
          "command": "tfplanColors.saveRenderedPlan",
          "when": "resourceScheme == tfplan-show",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "tfplanColors.saveRenderedPlan",
          "when": "resourceScheme == tfplan-show"
        },
        {
          "command": "tfplanColors.showSummary",
          "when": "editorLangId == terraform-plan"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "tfplanColors.binaryPlan",
        "displayName": "Terraform Plan",
        "selector": [
          {
            "filenamePattern": "**/tfplan"
          },
          {
            "filenamePattern": "**/tfplan.*"
          },
          {
            "filenamePattern": "**/*-tfplan"
          },
          {
            "filenamePattern": "**/*_tfplan"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "tfplanColors.binaryPlanOptional",
        "displayName": "Terraform Plan Preview",
        "selector": [
          {
            "filenamePattern": "*tfplan*"
          }
        ],
        "priority": "option"
      }
    ],
    "languages": [
      {
        "id": "terraform-plan",
        "aliases": [
          "Terraform Plan"
        ],
        "extensions": [
          ".tfplan"
        ],
        "filenamePatterns": [
          "*tfplan*"
        ],
        "firstLine": "^Terraform (used the selected providers|will perform)",
        "icon": {
          "light": "./fileicon.svg",
          "dark": "./fileicon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ]
  }
}
